<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>نظام شرطة Forest</title>

<style>

body{
background:#000;
color:white;
font-family:Tahoma;
padding:20px;
margin:0;
}

.section{
background:#111;
border:1px solid #0d6efd;
border-radius:15px;
padding:15px;
margin-bottom:20px;
}

.section h2{
color:#00aaff;
text-align:center;
margin-bottom:15px;
}

.accordion{
width:100%;
background:#0b2340;
color:white;
border:none;
padding:15px;
margin-top:10px;
border-radius:10px;
cursor:pointer;
font-size:18px;
text-align:right;
}

.accordion:hover{
background:#12345a;
}

.panel{
display:none;
background:#081829;
padding:15px;
margin-top:5px;
border-radius:10px;
border-right:4px solid #00aaff;
}

.speed-box{
background:#081829;
padding:15px;
border-radius:10px;
line-height:2;
}

.admin{
background:#111;
border:2px dashed #0d6efd;
border-radius:15px;
padding:20px;
text-align:center;
}

.admin input{
width:90%;
max-width:300px;
padding:12px;
background:#000;
border:1px solid #0d6efd;
border-radius:10px;
color:white;
}

.admin button{
margin-top:10px;
padding:12px 20px;
background:#0b2340;
color:white;
border:none;
border-radius:10px;
cursor:pointer;
}

.saveBtn{
display:none;
}

</style>
</head>
<body>

<div class="section">
<h2>سياسات المركز والممنوعات</h2>

<button class="accordion">▶ السياسات</button>
<div class="panel editable" contenteditable="false">
اكتب هنا...
</div>

<button class="accordion">▶ الممنوعات على المستجدين</button>
<div class="panel editable" contenteditable="false">
اكتب هنا...
</div>

</div>

<div class="section">

<h2>حدود السرعة</h2>

<div class="speed-box">

• مرآب الشرطة "طابق صفر" (25)<br>
• ڤينيس "VENICE" (لا يزيد عن 60)<br>
• كامبتون "CAMPTON" (بين 80-100)<br>
• في أماكن أخرى (لا يزيد عن 100)<br>
• حد السرعة في المنطقة الخضراء (40 ولا يتجاوز 60)

</div>

</div>

<div class="section">

<h2>سلسلة القيادة والرتب</h2>

<button class="accordion">▶ التسلسل الهرمي</button>
<div class="panel editable" contenteditable="false">
اكتب هنا...
</div>

<button class="accordion">▶ مهام كل رتب الفصيل</button>
<div class="panel editable" contenteditable="false">
اكتب هنا...
</div>

</div>

<div class="section">

<h2>نظام الترقيات</h2>

<button class="accordion">▶ ترقية من رتبة 0 إلى 1</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">▶ ترقية من رتبة 1 إلى 2</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">▶ ترقية من رتبة 2 إلى 3</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">▶ ترقية من رتبة 3 إلى 4</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">▶ ترقية من رتبة 4 إلى 5</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">▶ ترقية من رتبة 5 إلى 6</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">▶ ترقية من رتبة 6 إلى 7</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">▶ ترقية من رتبة 7 إلى 8</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">▶ ترقية من رتبة 8 إلى 9</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

</div>

<div class="section">

<h2>طريقة الاعتقال الصحيح</h2>

<button class="accordion">▶ اعتقال شخص مسلح أو غير مسلح</button>
<div class="panel editable" contenteditable="false">
اكتب هنا...
</div>

<button class="accordion">▶ طريقة استخدام التحذير الثالث (60 ثانية)</button>
<div class="panel editable" contenteditable="false">
اكتب هنا...
</div>

</div>

<div class="admin">

<h2>🔒 لوحة إدارة رئيس الفصيل (تعديل الأوامر)</h2>

<input type="password" id="password" placeholder="أدخل كلمة المرور">

<br>

<button onclick="login()">
تفعيل وضع التعديل
</button>

<br>

<button id="saveBtn" class="saveBtn" onclick="saveData()">
حفظ التعديلات
</button>

</div>

<script>

document.querySelectorAll(".accordion").forEach(btn=>{

btn.addEventListener("click",()=>{

let panel=btn.nextElementSibling;

if(panel.style.display==="block"){
panel.style.display="none";
}else{
panel.style.display="block";
}

});

});

function login(){

let pass=document.getElementById("password").value;

if(pass==="1221"){

document.querySelectorAll(".editable").forEach(item=>{

item.contentEditable=true;

});

document.getElementById("saveBtn").style.display="inline-block";

alert("تم تفعيل وضع التعديل");

}else{

alert("كلمة المرور غير صحيحة");

}

}

function saveData(){

let items=document.querySelectorAll(".editable");

items.forEach((item,index)=>{

localStorage.setItem("section"+index,item.innerHTML);

});

alert("تم حفظ التعديلات");

}

window.onload=function(){

let items=document.querySelectorAll(".editable");

items.forEach((item,index)=>{

let data=localStorage.getItem("section"+index);

if(data){

item.innerHTML=data;

}

});

}

</script>

</body>
</html>
